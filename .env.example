# OpenRouter API key (required for chat answers)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: legacy alias still supported
# HUNYUAN_API_KEY=

# LLM model on OpenRouter (must end with :free for this project)
LLM_MODEL=openai/gpt-oss-20b:free

# Optional comma-separated free fallbacks (tried on 429/404/503)
LLM_FALLBACK_MODELS=google/gemma-4-31b-it:free,google/gemma-4-26b-a4b-it:free,nvidia/nemotron-3-nano-30b-a3b:free,nvidia/nemotron-nano-9b-v2:free

# Comma-separated browser origins allowed by CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging level
LOG_LEVEL=INFO

# Max Chroma distance to treat a chunk as relevant (raise if refusals are too aggressive)
RETRIEVAL_MAX_DISTANCE=1.2
